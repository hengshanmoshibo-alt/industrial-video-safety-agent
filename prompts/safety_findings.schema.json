{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/industrial-video-safety-agent/safety_findings.schema.json",
  "title": "Industrial Safety VLM Findings",
  "type": "object",
  "additionalProperties": false,
  "required": ["findings"],
  "properties": {
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "label",
          "risk_level",
          "confidence",
          "timestamp_ms",
          "start_ms",
          "end_ms",
          "bbox",
          "reason",
          "recommendation",
          "evidence_caption"
        ],
        "properties": {
          "label": {
            "type": "string",
            "enum": [
              "safe_walkway",
              "authorized_intervention",
              "closed_panel_cover",
              "safe_carrying",
              "walkway_violation",
              "unauthorized_intervention",
              "opened_panel_cover",
              "forklift_overload"
            ]
          },
          "risk_level": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low", "needs_review"]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "timestamp_ms": {
            "type": "integer",
            "minimum": 0
          },
          "start_ms": {
            "type": "integer",
            "minimum": 0
          },
          "end_ms": {
            "type": "integer",
            "minimum": 0
          },
          "bbox": {
            "oneOf": [
              {
                "type": "array",
                "minItems": 4,
                "maxItems": 4,
                "items": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1000
                }
              },
              {
                "type": "null"
              }
            ]
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "recommendation": {
            "type": "string",
            "minLength": 1
          },
          "evidence_caption": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
